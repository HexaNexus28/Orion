# ORION Environment Configuration
# Copy this file to .env and fill in your values

# Supabase PostgreSQL connection
# Format: Host=db.xxx.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=xxx;SSL Mode=Require
SUPABASE_CONNECTION_STRING=your_supabase_connection_string_here

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=kimi-k2
OLLAMA_TIMEOUT_SECONDS=120

# Anthropic (fallback API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# Daemon WebSocket (future use)
DAEMON_WS_URL=ws://localhost:5001/ws
DAEMON_WS_TOKEN=your_secure_token_here

# JWT (if using auth)
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_ISSUER=OrionApi
JWT_AUDIENCE=OrionClient

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
