    <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.20.1" />
    <PackageReference Include="System.Diagnostics.PerformanceCounter" Version="9.0.0" />
    <PackageReference Include="System.Windows.Extensions" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Orion.Daemon.Core\Orion.Daemon.Core.csproj" />
    <ProjectReference Include="..\Orion.Daemon.Actions\Orion.Daemon.Actions.csproj" />
  </ItemGroup>

</Project>
