    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Orion.Daemon</RootNamespace>
    <AssemblyName>Orion.Daemon</AssemblyName>
    <OutputType>Exe</OutputType>
