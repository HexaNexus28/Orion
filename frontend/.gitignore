# =============================================================================
# ORION Frontend - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT FILES
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# -----------------------------------------------------------------------------
# DEPENDENCIES
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Lock files (optional - uncomment if you want to ignore)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# -----------------------------------------------------------------------------
# BUILD OUTPUTS
# -----------------------------------------------------------------------------
dist/
dist-ssr/
build/
out/
.cache/
.parcel-cache/
*.tsbuildinfo

# Vite
.vite/

# -----------------------------------------------------------------------------
# TESTING AND COVERAGE
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# EDITOR FILES
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# SYSTEM FILES
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# TEMPORARY FILES
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.log

# -----------------------------------------------------------------------------
# LARGE MODELS / BINARIES (if stored in public/ or src/)
# -----------------------------------------------------------------------------
*.onnx
*.bin
models/

# -----------------------------------------------------------------------------
# KEEP THESE
# -----------------------------------------------------------------------------
!.gitkeep
!.env.example
